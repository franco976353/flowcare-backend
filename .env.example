# Configuración del Backend para FlowCare
# No completes valores reales en este archivo, hacelo en tu servidor (Render/Railway) o en un archivo .env propio.

# Conexión con Neon PostgreSQL (Copiá estos del panel de Neon)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Secreto para firmar los tokens JWT (Cualquier frase larga y aleatoria)
JWT_SECRET="una_frase_muy_larga_y_secreta_aquí"

# Puerto (Render lo asignará automáticamente, podés dejarlo en 3000 por defecto)
PORT=3000
